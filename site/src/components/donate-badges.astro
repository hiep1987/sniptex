---
const sponsorsUrl = "https://github.com/sponsors/hiep1987";
const openCollectiveUrl = "https://opencollective.com/sniptex";

// Apple Developer Program fund — $0 raised, target $99/yr. Update when
// donations come in.
const fundRaised = 0;
const fundTarget = 99;
const fundPct = Math.min(100, Math.round((fundRaised / fundTarget) * 100));
---

<section id="donate" class="border-b border-ink-200 py-16 sm:py-20 dark:border-ink-800">
  <div class="container-wide">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-ink-950 sm:text-4xl dark:text-white">
        Help SnipTeX go signed
      </h2>
      <p class="mt-3 text-base text-ink-600 dark:text-ink-300">
        SnipTeX is free forever. Donations cover the
        <strong>Apple Developer Program ($99/yr)</strong> so the Mac app
        no longer needs "Open Anyway", and the
        <strong>Windows EV certificate (~$200/yr)</strong> so SmartScreen
        stops flagging the installer.
      </p>
    </div>

    <div class="mx-auto mt-10 max-w-2xl rounded-xl border border-ink-200 bg-white p-6 shadow-sm dark:border-ink-700 dark:bg-ink-900">
      <div class="flex items-center justify-between text-sm">
        <span class="font-medium text-ink-950 dark:text-white">
          Apple Developer Program · 2026
        </span>
        <span class="text-ink-500 dark:text-ink-400">
          ${fundRaised} / ${fundTarget}
        </span>
      </div>
      <div class="mt-2 h-2 overflow-hidden rounded-full bg-ink-200 dark:bg-ink-800">
        <div
          class="h-full rounded-full bg-gradient-to-r from-blue-500 to-violet-500 transition-[width] duration-300"
          style={`width: ${fundPct}%`}
        ></div>
      </div>
      <p class="mt-2 text-xs text-ink-500 dark:text-ink-400">
        {fundPct}% raised · once funded, all Mac releases go through Apple
        notarization for a one-click install experience.
      </p>
    </div>

    <div class="mx-auto mt-8 grid max-w-2xl gap-4 sm:grid-cols-2">
      <a
        href={sponsorsUrl}
        rel="noopener noreferrer"
        target="_blank"
        class="flex items-center justify-center gap-2 rounded-lg border border-pink-200 bg-pink-50 px-5 py-3 text-sm font-medium text-pink-700 transition hover:bg-pink-100 dark:border-pink-900 dark:bg-pink-950/40 dark:text-pink-200 dark:hover:bg-pink-900/40"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
        </svg>
        Sponsor on GitHub
      </a>
      <a
        href={openCollectiveUrl}
        rel="noopener noreferrer"
        target="_blank"
        class="flex items-center justify-center gap-2 rounded-lg border border-blue-200 bg-blue-50 px-5 py-3 text-sm font-medium text-blue-700 transition hover:bg-blue-100 dark:border-blue-900 dark:bg-blue-950/40 dark:text-blue-200 dark:hover:bg-blue-900/40"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2a10 10 0 100 20 10 10 0 000-20zm0 4l3 5h-2v5h-2v-5h-2l3-5z" />
        </svg>
        Open Collective
      </a>
    </div>

    <p class="mt-6 text-center text-xs text-ink-500 dark:text-ink-400">
      Or just star the repo on GitHub — it costs nothing and helps
      discovery a ton.
    </p>
  </div>
</section>
