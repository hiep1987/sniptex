---
import pkg from "../../package.json";

const repo = "https://github.com/hiep1987/sniptex";
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-200 bg-ink-50 py-12 dark:border-ink-800 dark:bg-ink-900">
  <div class="container-wide">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-4">
      <div>
        <p class="text-sm font-semibold text-ink-950 dark:text-white">SnipTeX</p>
        <p class="mt-2 text-xs text-ink-500 dark:text-ink-400">
          Free OCR snip tool for LaTeX &amp; Markdown.
          <br />
          v{pkg.version} · MIT License
        </p>
      </div>

      <div>
        <p class="text-xs font-medium uppercase tracking-wider text-ink-500 dark:text-ink-400">
          Project
        </p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="text-ink-700 hover:text-ink-950 dark:text-ink-300 dark:hover:text-white" href={repo}>GitHub</a></li>
          <li><a class="text-ink-700 hover:text-ink-950 dark:text-ink-300 dark:hover:text-white" href={`${repo}/issues`}>Issues</a></li>
          <li><a class="text-ink-700 hover:text-ink-950 dark:text-ink-300 dark:hover:text-white" href={`${repo}/releases`}>Releases</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs font-medium uppercase tracking-wider text-ink-500 dark:text-ink-400">
          Docs
        </p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="text-ink-700 hover:text-ink-950 dark:text-ink-300 dark:hover:text-white" href={`${repo}/blob/main/docs/install-guide.md`}>Install guide</a></li>
          <li><a class="text-ink-700 hover:text-ink-950 dark:text-ink-300 dark:hover:text-white" href={`${repo}/blob/main/docs/releasing.md`}>Releasing</a></li>
          <li><a class="text-ink-700 hover:text-ink-950 dark:text-ink-300 dark:hover:text-white" href="#vi">Tiếng Việt</a></li>
        </ul>
      </div>

      <div>
        <p class="text-xs font-medium uppercase tracking-wider text-ink-500 dark:text-ink-400">
          Community
        </p>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <span class="text-ink-500 dark:text-ink-400">Discord — coming at launch</span>
          </li>
          <li><a class="text-ink-700 hover:text-ink-950 dark:text-ink-300 dark:hover:text-white" href="https://github.com/sponsors/hiep1987">Sponsor</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-ink-200 pt-6 text-center text-xs text-ink-500 dark:border-ink-800 dark:text-ink-400">
      © {year} SnipTeX contributors. Built with Tauri, React, Rust, Astro.
    </div>
  </div>
</footer>
