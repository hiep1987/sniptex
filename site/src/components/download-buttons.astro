---
// Linking to GitHub's `/releases/latest` page rather than a direct
// `download/<filename>` URL because the asset filename embeds the version
// tag, which we don't know at build time. Once releases stabilize we can
// switch to a `/releases/latest/download/<name>` pattern (gh resolves
// "latest" server-side).
const releasesLatest = "https://github.com/hiep1987/sniptex/releases/latest";
---

<section id="download" class="border-b border-ink-200 py-16 sm:py-20 dark:border-ink-800">
  <div class="container-wide">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-ink-950 sm:text-4xl dark:text-white">
        Download
      </h2>
      <p class="mt-3 text-base text-ink-600 dark:text-ink-300">
        Pick your platform. SHA-256 checksums are listed in the release
        notes for manual verification.
      </p>
    </div>

    <div class="mx-auto mt-10 grid max-w-3xl gap-6 sm:grid-cols-2">
      <div class="rounded-xl border border-ink-200 bg-white p-6 shadow-sm dark:border-ink-700 dark:bg-ink-900">
        <div class="flex items-center gap-3">
          <svg class="size-7 text-ink-800 dark:text-ink-100" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.05 12.04c-.02-2.13 1.74-3.16 1.82-3.21-1-1.45-2.55-1.65-3.1-1.67-1.31-.13-2.57.77-3.24.77-.67 0-1.71-.75-2.82-.73-1.45.02-2.79.84-3.54 2.14-1.51 2.62-.39 6.49 1.08 8.62.72 1.04 1.58 2.21 2.69 2.17 1.09-.04 1.5-.7 2.81-.7 1.31 0 1.69.7 2.83.68 1.17-.02 1.91-1.05 2.62-2.1.83-1.2 1.17-2.36 1.19-2.42-.03-.01-2.28-.87-2.3-3.45zm-2.15-6.34c.6-.73 1.01-1.74.9-2.74-.87.04-1.93.58-2.56 1.31-.56.64-1.05 1.68-.92 2.66.97.07 1.97-.49 2.58-1.23z" />
          </svg>
          <h3 class="text-lg font-semibold text-ink-950 dark:text-white">
            macOS
          </h3>
        </div>
        <p class="mt-2 text-sm text-ink-500 dark:text-ink-400">
          Apple Silicon · macOS 12+ · ad-hoc signed DMG
        </p>
        <a href={releasesLatest} class="btn-primary mt-4 w-full">
          Download .dmg
        </a>
        <p class="mt-3 text-[11px] text-ink-500 dark:text-ink-400">
          Homebrew Cask coming with the v0.1.0 launch.
        </p>
      </div>

      <div class="rounded-xl border border-ink-200 bg-white p-6 shadow-sm dark:border-ink-700 dark:bg-ink-900">
        <div class="flex items-center gap-3">
          <svg class="size-7 text-ink-800 dark:text-ink-100" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M2 12V6.5l9-1.3V12H2zm0 .9h9v6.9l-9-1.3v-5.6zM12 5l10-1.5V12H12V5zm0 7.9h10V20.5L12 19v-6.1z" />
          </svg>
          <h3 class="text-lg font-semibold text-ink-950 dark:text-white">
            Windows
          </h3>
        </div>
        <p class="mt-2 text-sm text-ink-500 dark:text-ink-400">
          x64 · Windows 11 · unsigned MSI (SmartScreen workaround needed)
        </p>
        <a href={releasesLatest} class="btn-primary mt-4 w-full">
          Download .msi
        </a>
        <p class="mt-3 text-[11px] text-ink-500 dark:text-ink-400">
          One-line PowerShell installer coming with the v0.1.0 launch.
        </p>
      </div>
    </div>

    <p class="mt-6 text-center text-xs text-ink-500 dark:text-ink-400">
      Need a previous version or just the binaries?
      <a href="https://github.com/hiep1987/sniptex/releases" class="text-blue-600 hover:underline dark:text-blue-400">
        Browse all releases
      </a>
    </p>
  </div>
</section>

<script>
  function highlightOsButton() {
    const ua = navigator.userAgent;
    const isMac = /Mac|iPhone|iPad/i.test(ua);
    const isWin = /Windows/i.test(ua);
    if (!isMac && !isWin) return;
    const cards = document.querySelectorAll<HTMLElement>("#download .rounded-xl");
    cards.forEach((card, idx) => {
      const isMacCard = idx === 0;
      const matchesOs = (isMac && isMacCard) || (isWin && !isMacCard);
      if (matchesOs) {
        card.classList.add("ring-2", "ring-blue-500", "ring-offset-2", "dark:ring-offset-ink-950");
      }
    });
  }
  highlightOsButton();
</script>
